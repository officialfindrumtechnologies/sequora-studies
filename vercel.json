{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/app(.*)", "destination": "/index.html" },
    { "source": "/", "destination": "/landing.html" }
  ],
  "crons": [
    { "path": "/api/cron/expiry-check", "schedule": "0 9 * * *" }
  ]
}
